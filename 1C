def load_secrets():
    if not os.path.exists(KEY_PATH):
        raise FileNotFoundError(f"Нет ключа шифрования: {KEY_PATH}")
    with open(KEY_PATH, "rb") as f:
        fer = Fernet(f.read())
    def dec(tok):
        return fer.decrypt(tok.encode("ascii")).decode("utf-8")
    return (dec(SQL_USER_ENC), dec(SQL_PASSWORD_ENC),
            dec(AD_USER_ENC),  dec(AD_PASSWORD_ENC))

def send_alert(subject, body):
    try:
        msg = MIMEText(body, "plain", "utf-8")
        msg["Subject"] = Header(subject, "utf-8")
        msg["From"] = f"{Header(SENDER_NAME,'utf-8').encode()} <{SENDER_EMAIL}>"
        msg["To"] = ALERT_TO
        with smtplib.SMTP(SMTP_HOST, SMTP_PORT, timeout=30) as s:
            s.sendmail(SENDER_EMAIL, [ALERT_TO], msg.as_string())
    except Exception as e:
        logger.error(f"[ALERT FAIL] {e}")

def fatal(subject, err):
    body = f"Хост: {socket.gethostname()}\nСкрипт: {sys.argv[0]}\nDRY_RUN: {DRY_RUN}\n\n{err}"
    logger.error(f"[FATAL] {subject}\n{body}")
    send_alert(f"[AD Division Sync] {subject}", body)
    sys.exit(1)

def cleanup_old_logs():
    cutoff = time.time() - LOG_RETENTION_DAYS * 86400
    removed = 0
    for name in os.listdir(LOG_DIR):
        if not (name.endswith(".log") or name.endswith(".csv")):
            continue
        full = os.path.join(LOG_DIR, name)
        try:
            if os.path.isfile(full) and os.path.getmtime(full) < cutoff:
                os.remove(full)
                removed += 1
        except Exception as e:
            logger.warning(f"не смог удалить {full}: {e}")
    if removed:
        logger.info(f"Удалено старых файлов логов (>{LOG_RETENTION_DAYS} дн.): {removed}")

def norm_tab(v):
    if v is None: return None
    s = "".join(ch for ch in str(v).strip() if ch.isdigit())
    if not s: return None
    return s.zfill(10)

def is_empty(v):
    return v is None or not str(v).strip()

def load_excluded():
    if not os.path.exists(EXCL_PATH): return set()
    with open(EXCL_PATH, "r", encoding="utf-8") as f:
        return {norm_tab(x) for x in f if norm_tab(x)}

def load_dictionary():
    if not os.path.exists(XLSX_PATH):
        raise FileNotFoundError(f"Не найден справочник: {XLSX_PATH}")
    wb = load_workbook(XLSX_PATH, data_only=True)
    result = {}
    for sheet in ("department", "dep", "dep1"):
        if sheet not in wb.sheetnames:
            raise ValueError(f"В справочнике нет листа '{sheet}'")
        ws = wb[sheet]
        d = {}
        rows = ws.iter_rows(values_only=True)
        next(rows, None)
        for row in rows:
            if not row or len(row) < 2: continue
            block, name = row[0], row[1]
            if name is None or block is None: continue
            d[str(name).strip().lower()] = str(block).strip()
        result[sheet] = d
    return result
