import tkinter as tk
from tkinter import scrolledtext
import subprocess
def add_path():
    """Добавляет путь из поля ввода в список"""
    path = entry.get().strip()
    if path:
        listbox.insert(tk.END, path)
        entry.delete(0, tk.END)  # Очищаем поле ввода
    else:
        tk.messagebox.showwarning("Предупреждение", "Введите путь перед добавлением")
def remove_path():
    """Удаляет выбранный путь из списка"""
    selected = listbox.curselection()
    if selected:
        listbox.delete(selected)
def clear_paths():
    """Очищает весь список путей"""
    listbox.delete(0, tk.END)
def run_script():
    """Выполняет проверку для всех путей в списке"""
    paths = list(listbox.get(0, tk.END))
    if not paths:
        text_area.delete(1.0, tk.END)
        text_area.insert(1.0, "Ошибка: Добавьте хотя бы один путь к папке")
        return
    text_area.delete(1.0, tk.END)
    text_area.insert(1.0, "Выполнение скрипта...\n\n")
    root.update()
    # Формируем массив путей для PowerShell
    paths_array = '@("' + '", "'.join(paths) + '")'
    # PowerShell скрипт
    ps_script = f"""
$pathArray = {paths_array}
foreach ($pat in $pathArray)
{{
    Write-Host " Путь: $pat " -ForegroundColor Yellow
    $warningCheck = $false
    try
    {{
        $accessRules = (Get-Acl -Path $pat).Access
    }}
    catch
    {{
        Write-Warning "Не удалось получить ACL для пути: $pat"
        continue
    }}
    
    Write-Host " ВСЕ ПОЛЬЗОВАТЕЛИ " -ForegroundColor Green
    $allUsers = @()
    foreach ($rule in $accessRules)
    {{
        $full = $rule.IdentityReference.Value
        $allUsers += [PSCustomObject]@{{
            Original = $full
            Identity = $full.Split('\\')[-1]
        }}
    }}
    $allUsers | Format-Table -AutoSize
    # Выводим только FSDPT и FSGL
    Write-Host " ПОЛЬЗОВАТЕЛИ FSDPT/FSGL " -ForegroundColor Green
    $filteredUsers = @()
    foreach ($rule in $accessRules)
    {{
        $full = $rule.IdentityReference.Value
        $identity = $full.Split('\\')[-1]
        if($identity -like "FSDPT*" -or $identity -like "FSGL*" -or $identity -like "*ОФ*")
        {{
            $filteredUsers += [PSCustomObject]@{{
                Original = $full
                Identity = $identity
            }}
        }}
    }}
    $filteredUsers | Format-Table -AutoSize
}}
"""
    result = subprocess.run(["powershell", "-Command", ps_script],
                           capture_output=True,
                           text=True,
                           encoding='cp866',
                           errors='replace')
    # Очищаем вывод от дублей
    output = result.stdout
    lines = output.split('\n')
    unique_lines = []
    for line in lines:
        if line.strip() not in [l.strip() for l in unique_lines[-5:]]:
            unique_lines.append(line)
    output = '\n'.join(unique_lines)
    text_area.insert(tk.END, output)
    if result.stderr:
        text_area.insert(tk.END, f"\n\nОшибки:\n{result.stderr}")
