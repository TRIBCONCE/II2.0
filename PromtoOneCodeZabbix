            $DivisionCount[$div]++
        } else {
            $DivisionCount[$div] = 1
        }
    } else {
        $emptyKey = "(не указано)"
        if ($DivisionCount.ContainsKey($emptyKey)) {
            $DivisionCount[$emptyKey]++
        } else {
            $DivisionCount[$emptyKey] = 1
        }
    }
}

# Формирование discovery-данных для Zabbix LLD

