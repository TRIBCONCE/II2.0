        private bool SetMofficeTab(string displayName, string tabnumber)
        {
            bool done = false;
            try {
                using (DirectoryEntry entry = new DirectoryEntry("LDAP://DC=moffice,DC=akbars,DC=ru",set.MofficeUser,set.MofficePass))
                {
                    using (DirectorySearcher search = new DirectorySearcher(entry))
                    {
                        search.Filter = "(&(objectClass=User)(displayName=" + displayName + "))";

                        SearchResult result = search.FindOne();
                        DirectoryEntry user = result.GetDirectoryEntry();
                        if (user.Properties.Contains("wWWHomePage"))
                        {

                            LogWrite("wWWHomePage " + tabnumber);
                            user.Properties["wWWHomePage"].Value = tabnumber;
                            Thread.Sleep(100);
                        }
                        else
                        {
                            LogWrite("employeeID " + tabnumber);

                            user.Properties["employeeID"].Add(tabnumber);
                        }
                        if (user.Properties.Contains("employeeID"))
                        {
                            LogWrite("employeeID " + tabnumber);
                            user.Properties["employeeID"].Value = tabnumber;
                            Thread.Sleep(100);
                        }
                        else
                        {
                            LogWrite("employeeID " + tabnumber);

                            user.Properties["employeeID"].Add(tabnumber);
                        }
                    }
                }
            }
            catch(Exception ex)
            {
                LogWrite(ex.Message);
            }
                        return done;
        }
