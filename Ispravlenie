cls

$timestart = Get-Date
$today = (Get-Date).Date

$time = Get-Date -Format "dd.MM.yyyy HH:mm"


$TXT_PATH   = "\\abb-win.akbars.ru\departments\AppDS\1CKadryIntegration\Список.txt"
$XLSX_PATH  = "\\p-rpait-syn01\c$\Scripts\AD_Division_Attr\Справочник.xlsx"
$OUTPUT_PATH = "\\p-rpait-syn01\c$\Program Files\Zabbix Agent\scripts\AD\ADData_UsersBlocks_Discovery 1C.txt"


$DEFAULT_BLOCK = "Дополнительные офисы"
$UNKNOWN_BLOCK = "(не указано)"


$excel = New-Object -ComObject Excel.Application
$excel.Visible = $false
$excel.DisplayAlerts = $false

try {
    $workbook = $excel.Workbooks.Open($XLSX_PATH)
    
    $dict = @{}
    
    foreach ($sheetName in @("department", "dep", "dep1")) {
        $worksheet = $workbook.Worksheets.Item($sheetName)
        $sheetDict = @{}
        
        $row = 2
        while ($worksheet.Cells.Item($row, 1).Text -ne "") {
            $block = $worksheet.Cells.Item($row, 1).Text.Trim()
            $name  = $worksheet.Cells.Item($row, 2).Text.Trim()
            
            if ($block -and $name) {
                $sheetDict[$name.ToLower()] = $block
            }
            $row++
        }
        
        $dict[$sheetName] = $sheetDict
    }
    
    $workbook.Close($false)
} finally {
    $excel.Quit()
    [System.Runtime.Interopservices.Marshal]::ReleaseComObject($excel) | Out-Null
}


$Users1C = Import-Csv -Delimiter ";" -Path $TXT_PATH -WarningAction SilentlyContinue | Where-Object { 
    $_.decret -eq "0" -and ([string]::IsNullOrWhiteSpace($_.date_uv) -or ([datetime]::ParseExact($_.date_uv, "dd.MM.yyyy", $null) -ge $today.Date))
}



function Resolve-Block {
    param($Employee, $Dictionary)
    
    $podr = $Employee.podr
    if (-not [string]::IsNullOrWhiteSpace($podr)) {
        $parts = $podr -split '%' | ForEach-Object { $_.Trim() }
        
        foreach ($part in $parts) {
            if (-not $part) { continue }
            
            foreach ($sheet in @("department", "dep", "dep1")) {
                $block = $Dictionary[$sheet][$part.ToLower()]
                if ($block) {
                    return $block
                }
            }
        }
    }
    
    if (-not [string]::IsNullOrWhiteSpace($Employee.vid_zan)) {
        return $DEFAULT_BLOCK
    }
    
    return $UNKNOWN_BLOCK
}

Write-Host "`nПодсчёт по блокам" -ForegroundColor Green

$DivisionCount = @{}
$ExcludedCount = 0

foreach ($User in $Users1C) {
    $block = Resolve-Block -Employee $User -Dictionary $dict
    
    if ($DivisionCount.ContainsKey($block)) {
        $DivisionCount[$block]++
    } else {
        $DivisionCount[$block] = 1
    }
}

$RealUsersCount = ($DivisionCount.Values | Measure-Object -Sum).Sum


Write-Host "Всего уникальных значений: $($DivisionCount.Count)`n"

$DivisionCount.GetEnumerator() | 
    Sort-Object Value -Descending | 
    Format-Table @{Label="Подразделение"; Expression={$_.Key}; Width=50}, 
                 @{Label="Кол-во"; Expression={$_.Value}; Width=10}, 
                 @{Label="%"; Expression={"{0:P2}" -f ($_.Value / $RealUsersCount)}; Width=10} -AutoSize

Write-Host "Всего активных сотрудников в 1С: $($Users1C.Count)" -ForegroundColor Yellow
Write-Host "Реальных пользователей для анализа: $RealUsersCount" -ForegroundColor Green

#Write-Host "`n=== Формирование JSON ===" -ForegroundColor Green


$discovery = foreach ($k in $DivisionCount.Keys | Sort-Object) {
    @{ '{#DIVISION}' = $k }
}

$payload = [ordered]@{
    discovery = @($discovery)
    counts    = $DivisionCount
    metadata  = @{
        TotalActiveUsers  = $Users1C.Count
        ExcludedUsers     = 0
        RealUsers         = $RealUsersCount
        UniqueDivisions   = $DivisionCount.Count
        GeneratedAt       = $time
        ScriptDurationSec = [math]::Round(((Get-Date) - $timestart).TotalSeconds, 2)
    }
}

# Конвертация в JSON
$json = $payload | ConvertTo-Json -Depth 4

# Сохранение в файл
$outputDir = Split-Path $OUTPUT_PATH -Parent
if (-not (Test-Path $outputDir)) {
    New-Item -ItemType Directory -Path $outputDir -Force | Out-Null
}

[System.IO.File]::WriteAllText($OUTPUT_PATH, $json, [System.Text.UTF8Encoding]::new($false))


