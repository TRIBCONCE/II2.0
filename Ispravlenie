cls
Import-Module ActiveDirectory

# === ВПИШИТЕ ИМЯ ГРУППЫ СЮДА ===
$GroupName = "ИМЯ_ВАШЕЙ_ГРУППЫ"
$OutputFile = "C:\Users\z-BorodinES\Desktop\Выгрузка_$GroupName.csv"

# Указываем свойства, которые нужно вытащить из AD
$Properties = @(
    "Name", 
    "Enabled", 
    "EmployeeID", 
    "EmailAddress", 
    "Title", 
    "Division", 
    "Department", 
    "extensionAttribute1", 
    "extensionAttribute2"
)

# Получаем состав группы, оставляем только пользователей (отсекаем вложенные группы) и собираем данные
$data = Get-ADGroupMember -Identity $GroupName | 
    Where-Object { $_.objectClass -eq 'user' } | 
    Get-ADUser -Properties $Properties | 
    Select-Object @{
        Name = "ФИО"
        Expression = { $_.Name }
    }, @{
        Name = "Статус (вкл/выкл)"
        Expression = { if ($_.Enabled) { "Вкл" } else { "Выкл" } }
    }, @{
        Name = "ТН"
        Expression = { $_.EmployeeID }
    }, @{
        Name = "Почта"
        Expression = { $_.EmailAddress }
    }, @{
        Name = "Блок"
        Expression = { $_.Division } # Если блок хранится в Department, поменяйте на $_.Department
    }, @{
        Name = "Должность"
        Expression = { $_.Title }
    }, @{
        Name = "Ext Атрибут 1"
        Expression = { $_.extensionAttribute1 }
    }, @{
        Name = "Ext Атрибут 2"
        Expression = { $_.extensionAttribute2 }
    }

# Выгружаем в CSV
$data | Export-Csv -Path $OutputFile -NoTypeInformation -Encoding UTF8 -Delimiter ";"
Write-Host "Файл CSV сохранен: $OutputFile" -ForegroundColor Green

# Открываем файл
Invoke-Item $OutputFile