
def resolve_block(emp, dic):
    for field in ("department", "dep", "dep1"):
        v = emp.get(field)
        if not is_empty(v):
            block = dic[field].get(str(v).strip().lower())
            if block:
                return block, f"matched_{field}", "update"
            else:
                return None, f"unknown_{field}:{v}", "unknown"
    if not is_empty(emp.get("dokko")):
        return DEFAULT_BLOCK, "default_by_dokko", "update"
    return UNKNOWN_BLOCK, "no_data_no_dokko", "stats"

def fetch_employees(sql_user, sql_pwd):
    conn_str = (f"DRIVER={{ODBC Driver 17 for SQL Server}};SERVER={SQL_SERVER};"
                f"DATABASE={SQL_DATABASE};UID={sql_user};PWD={sql_pwd};")
    try:
        cn = pyodbc.connect(conn_str, timeout=15)
    except Exception:
        fatal("Недоступна БД DWDATA_ODS", traceback.format_exc())
    cur = cn.cursor()
    cur.execute(f"""
        SELECT Tab_Numb, fio, UvDate, department, dep, dep1, dokko
        FROM {SQL_DATABASE}.{SQL_VIEW}
    """)
    today = datetime.now().date()
    out = []
    for r in cur.fetchall():
        uv = r.UvDate
        if uv is not None:
            try:
                if uv.date() <= today: continue
            except AttributeError:
                pass
        tab = norm_tab(r.Tab_Numb)
        if not tab: continue
        out.append({"tab": tab, "fio": r.fio or "",
                    "department": r.department, "dep": r.dep, "dep1": r.dep1,
                    "dokko": r.dokko})
    cn.close()
    return out

def connect_ad(ad_user, ad_pwd):
    try:
        srv = Server(AD_SERVER, get_info=ALL)
        c = Connection(srv, user=ad_user, password=ad_pwd,
                       authentication="SIMPLE", auto_bind=True)
        return c
    except Exception:
        fatal("Не удалось подключиться к AD", traceback.format_exc())

def load_ad_users(conn):
    flt = ("(&(objectClass=user)(objectCategory=person)(wWWHomePage=*)"
           "(!(sAMAccountName=z-*))(!(sAMAccountName=a-*))(!(sAMAccountName=s-*))"
           "(!(employeeType=vendor))(!(employeeType=service)))")
    attrs = ["sAMAccountName", "distinguishedName", "division",
             "wWWHomePage", "userAccountControl",
             "physicalDeliveryOfficeName", "streetAddress"]
    index = {}
    disabled_index = {}
    total = 0
    skipped_disabled_ou = 0
    for entry in conn.extend.standard.paged_search(
            search_base=AD_BASE_DN, search_filter=flt,
            search_scope=SUBTREE, attributes=attrs,
            paged_size=500, generator=True):
        if entry.get("type") != "searchResEntry":
            continue
        a = entry["attributes"]
        dn = entry["dn"]
        uac = a.get("userAccountControl") or 0
        try:
            uac = int(uac)
        except (TypeError, ValueError):
            uac = 0
        is_disabled = bool(uac & UAC_DISABLED)

        tab = norm_tab(a.get("wWWHomePage"))
        if not tab:
            continue

        if is_disabled and any(m in dn.lower() for m in EXCLUDED_OU_MARKERS):
            skipped_disabled_ou += 1
            disabled_index.setdefault(tab, []).append(a.get("sAMAccountName") or "")
            continue

        index.setdefault(tab, []).append({
            "sam": a.get("sAMAccountName") or "",
            "dn":  dn,
            "division": a.get("division") or "",
            "disabled": is_disabled,
            "office": a.get("physicalDeliveryOfficeName") or "",
            "street": a.get("streetAddress") or "",
        })
        total += 1
        if total % 1000 == 0:
            logger.info(f"  AD загружено: {total}")
    logger.info(f"  AD итого записей: {total}, уникальных табельников: {len(index)}, "
                f"пропущено отключенных в спец-OU: {skipped_disabled_ou}")
