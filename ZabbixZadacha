Смотри у меня вот есть код который собирает данные по отпускам сотрудников, мне надо сделать новую логику и собирать только тех сотрудников которые находятся в отпуске на момент исполнения скрипта тоесть сегодня

function Invoke-Sql([string]$q){
  $cs="Server=$SqlServer;Database=$SqlDb;User Id=$SqlUser;Password=$SqlPass;"
  $cn=New-Object System.Data.SqlClient.SqlConnection $cs; $cn.Open()
  $cmd=$cn.CreateCommand(); $cmd.CommandText=$q
  $da=New-Object System.Data.SqlClient.SqlDataAdapter $cmd
  $dt=New-Object System.Data.DataTable; [void]$da.Fill($dt); $cn.Close(); ,$dt
}

$qF=@"
SELECT e.LastName,e.FirstName,e.MiddleName,e.Tab_Numb,e.IDPerson,
       f.StartDate,f.EndDate,f.CountDay,f.FurloughTypeID
FROM IC.Furlough_WT f
JOIN IC.Empl_WT_USPS e ON e.EmplID=f.EmplID
WHERE e.UvDate IS NULL
  AND f.StartDate>=CAST(GETDATE() AS date)
  AND f.StartDate<=DATEADD(day,$Days,CAST(GETDATE() AS date))
ORDER BY f.StartDate,e.LastName
"@
$qE="SELECT DISTINCT IDPerson,email FROM IC.v_Empl_info WHERE email IS NOT NULL AND LTRIM(RTRIM(email))<>''"

$F=Invoke-Sql $qF
$E=Invoke-Sql $qE

# IDPerson -> список email из вьюхи
$mail=@{}
foreach($r in $E.Rows){
  $id="$($r.IDPerson)"
  if(-not $mail.ContainsKey($id)){ $mail[$id]=New-Object System.Collections.ArrayList }
  [void]$mail[$id].Add([string]$r.email)
}

# AD: один запрос — все обычные Enabled УЗ с табельником и почтой -> хеш по табельнику
$adByTab=@{}
Get-ADUser -LDAPFilter "(&(wWWHomePage=*)(mail=*)(!(userAccountControl:1.2.840.113556.1.4.803:=2)))" `
  -Properties mail,wWWHomePage,SamAccountName -Server $AdServer -Credential $AdCred |
  Where-Object { $_.SamAccountName -notmatch '^(z|s|a)-' } |
  ForEach-Object {
    $t="$($_.wWWHomePage)".Trim()
    if($t){
      if(-not $adByTab.ContainsKey($t)){ $adByTab[$t]=New-Object System.Collections.ArrayList }
      [void]$adByTab[$t].Add($_.mail)
    }
  }

$rows=foreach($r in $F.Rows){
  $id="$($r.IDPerson)"; $tab="$($r.Tab_Numb)"
  $list= if($mail.ContainsKey($id)){ @($mail[$id]) } else { @() }
  $primary = $list | Select -First 1
  $src = if($primary){"1C"}else{""}
  if(-not $primary){                       # fallback в AD по табельнику (из хеша)
    if($adByTab.ContainsKey($tab)){
      $adm=@($adByTab[$tab])
      if($adm.Count -eq 1){ $primary=$adm[0]; $src="AD" }
      else { $primary="AD_MULTI:"+($adm -join ","); $src="AD_MULTI" }
    }
  }
  [PSCustomObject]@{
    ФИО      = ("{0} {1} {2}" -f $r.LastName,$r.FirstName,$r.MiddleName).Trim()
    Почта    = $primary
    Источник = $src
    Табель   = $tab
    Начало   = ([datetime]$r.StartDate).ToString("dd.MM.yyyy")
    Конец    = ([datetime]$r.EndDate).ToString("dd.MM.yyyy")
    Дней     = $r.CountDay
    EmailCnt = @($list).Count
    Emails   = ($list -join "; ")
    IDPerson = $id
  }
}

$rows | Select ФИО,Почта,Источник,Табель,Начало,Конец,Дней | Format-Table -AutoSize
$noMail=@($rows|?{-not $_.Почта})
$ambig =@($rows|?{$_.EmailCnt -gt 1})
$adMulti=@($rows|?{$_.Источник -eq 'AD_MULTI'})
$fromAd=@($rows|?{$_.Источник -eq 'AD'})
Write-Host "`nВсего: $($rows.Count) | без почты: $($noMail.Count) | из AD: $($fromAd.Count) | AD-мультидубль: $($adMulti.Count) | неоднозн.(1С): $($ambig.Count)" -ForegroundColor Cyan

$dir= if($PSScriptRoot){$PSScriptRoot} elseif($MyInvocation.MyCommand.Path){Split-Path $MyInvocation.MyCommand.Path} else {(Get-Location).Path}
$st=Get-Date -Format yyyyMMdd
$rows | Select ФИО,Почта,Источник,Табель,Начало,Конец,Дней | Export-Csv (Join-Path $dir "furlough_$st.csv") -NoTypeInformation -Encoding UTF8
if($ambig.Count){
  $ambig | Select ФИО,Табель,IDPerson,Emails | Export-Csv (Join-Path $dir "furlough_ambiguous_$st.csv") -NoTypeInformation -Encoding UTF8
  Write-Host "Неоднозначные email (1С) -> furlough_ambiguous_$st.csv" -ForegroundColor Yellow
}
if($adMulti.Count){
  $adMulti | Select ФИО,Табель,Почта | Export-Csv (Join-Path $dir "furlough_admulti_$st.csv") -NoTypeInformation -Encoding UTF8
  Write-Host "AD: несколько УЗ на табельник -> furlough_admulti_$st.csv" -ForegroundColor Yellow
}
