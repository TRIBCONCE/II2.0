    $DivisionCount.GetEnumerator() | Sort-Object Value -Descending | ForEach-Object {
        $percent = "{0:P2}" -f ($_.Value / $RealUsersCount)
        Write-Log ("{0,-60} {1,6} {2,8}" -f $_.Key, $_.Value, $percent)
    }

    $DivisionCount.GetEnumerator() | Sort-Object Value -Descending |
        Format-Table @{Label="Подразделение"; Expression={$_.Key}; Width=50},
