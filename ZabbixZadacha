        $block = Resolve-Block -E $User -Dict $dict
        if ($DivisionCount.ContainsKey($block)) { $DivisionCount[$block]++ }
        else { $DivisionCount[$block] = 1 }
    }

    $RealUsersCount = ($DivisionCount.Values | Measure-Object -Sum).Sum

    Write-Log ""
    Write-Log "СТАТУС: $ScriptStatus"
    Write-Log "Подсчёт по блокам (1С)"
