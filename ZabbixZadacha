  $cmd=$cn.CreateCommand(); $cmd.CommandText=$q
  $da=New-Object System.Data.SqlClient.SqlDataAdapter $cmd
  $dt=New-Object System.Data.DataTable; [void]$da.Fill($dt); $cn.Close(); ,$dt
}

try {
    Write-Host "`n[1/3] Чтение справочника Excel (через COM-объект)..." -ForegroundColor Cyan
    
    # --- Справочник Excel (через COM-объект, как было в твоем оригинале) ---
    $excel = New-Object -ComObject Excel.Application
    $excel.Visible = $false
    $excel.DisplayAlerts = $false
    $dict = @{}

    try {
        $workbook = $excel.Workbooks.Open($XLSX_PATH)

        foreach ($sheetName in @("department", "dep", "dep1")) {
            $worksheet = $workbook.Worksheets.Item($sheetName)
            $sheetDict = @{}

            $row = 2
            while ($worksheet.Cells.Item($row, 1).Text -ne "") {
                $block = $worksheet.Cells.Item($row, 1).Text.Trim()
                $name  = $worksheet.Cells.Item($row, 2).Text.Trim()

                if ($block -and $name) {
                    $sheetDict[$name.ToLower()] = $block
                }
                $row++
            }
            $dict[$sheetName] = $sheetDict
        }
        $workbook.Close($false)
    } finally {
        $excel.Quit()
        [System.Runtime.Interopservices.Marshal]::ReleaseComObject($excel) | Out-Null
    }

    Write-Host "[2/3] Получение данных из БД 1С..." -ForegroundColor Cyan

    # --- Сотрудники из БД ---
    $sql = @"
    SELECT department, dep, dep1, dokko
    FROM IC.v_Empl_info
    WHERE DecrOtpusk = 0
      AND (UvDate IS NULL OR UvDate > CAST(GETDATE() AS date))
      AND Synonym = N'Основное место работы'
      AND fio IS NOT NULL AND LTRIM(RTRIM(fio)) <> ''
"@

    $dt = Invoke-Sql $sql
    $Users1C = $dt.Rows

    # --- Определение блока: перебор всех уровней по всем листам ---
    function Resolve-Block {
        param($E, $Dict)
        foreach ($f in @("department","dep","dep1")) {
            $v = ([string]$E.$f).Trim()
            if ($v) {
                $k = $v.ToLower()
                foreach ($sheet in @("department","dep","dep1")) {
                    $b = $Dict[$sheet][$k]
                    if ($b) { return $b }
                }
            }
        }
        if (([string]$E.dokko).Trim()) { return $DEFAULT_BLOCK }
        return $NODATA_BLOCK
    }

    $DivisionCount = @{}
    foreach ($User in $Users1C) {
        $block = Resolve-Block -E $User -Dict $dict
        if ($DivisionCount.ContainsKey($block)) { $DivisionCount[$block]++ }
        else { $DivisionCount[$block] = 1 }
    }

    $RealUsersCount = ($DivisionCount.Values | Measure-Object -Sum).Sum

    # Запись в лог-файл

    $DivisionCount.GetEnumerator() | Sort-Object Value -Descending | ForEach-Object {
        $percent = "{0:P2}" -f ($_.Value / $RealUsersCount)
    }

    # --- ТРЕБУЕМЫЙ ВЫВОД СТАТИСТИКИ ПО БЛОКАМ В КОНСОЛЬ ---
    Write-Host "`nПодсчёт по блокам" -ForegroundColor Green
    Write-Host "Всего уникальных значений: $($DivisionCount.Count)`n"

    $DivisionCount.GetEnumerator() |
        Sort-Object Value -Descending |
        Format-Table @{Label="Подразделение"; Expression={$_.Key}; Width=50},
                     @{Label="Кол-во"; Expression={$_.Value}; Width=10},
                     @{Label="%"; Expression={
                         if ($RealUsersCount -gt 0) { "{0:P2}" -f ($_.Value / $RealUsersCount) } else { "0,00%" }
                     }; Width=10} -AutoSize

    Write-Host "Всего активных сотрудников в 1С: $($Users1C.Count)" -ForegroundColor Yellow
    Write-Host "Реальных пользователей для анализа: $RealUsersCount" -ForegroundColor Green

    # Для Zabbix исключаем служебную категорию "(не указано)" — она остаётся только в логах
    $ZabbixCount = @{}
    foreach ($k in $DivisionCount.Keys) {
        if ($k -ne $NODATA_BLOCK) { $ZabbixCount[$k] = $DivisionCount[$k] }
    }

    # --- ФОРМИРОВАНИЕ ZABBIX DISCOVERY ---
    Write-Host "`n[3/3] Формирование Zabbix Discovery JSON..." -ForegroundColor Cyan
    $discovery = foreach ($k in $ZabbixCount.Keys | Sort-Object) { @{ '{#DIVISION}' = $k } }

    $payload = [ordered]@{
        discovery = @($discovery)
        counts    = $ZabbixCount
        metadata  = @{
            TotalActiveUsers  = $Users1C.Count
            ExcludedUsers     = 0
            RealUsers         = $RealUsersCount
            UniqueDivisions   = $ZabbixCount.Count
            GeneratedAt       = $time
            ScriptDurationSec = [math]::Round(((Get-Date) - $timestart).TotalSeconds, 2)
        }
    }

    $json = $payload | ConvertTo-Json -Depth 4

   # $outputDir = Split-Path $OUTPUT_PATH -Parent
    #if (-not (Test-Path $outputDir)) { New-Item -ItemType Directory -Path $outputDir -Force | Out-Null }
   # [System.IO.File]::WriteAllText($OUTPUT_PATH, $json, [System.Text.UTF8Encoding]::new($false))

    $timestop = Get-Date
    $TimeSum = $timestop - $timestart
    Write-Host "Время выполнения: $($TimeSum.Hours)ч $($TimeSum.Minutes)м $($TimeSum.Seconds)с" -ForegroundColor Cyan
    Write-Host "Файл успешно сохранён: $OUTPUT_PATH" -ForegroundColor Green

}
catch {
    $ScriptStatus = "ERROR"
    Write-Host "`nОШИБКА: $($_.Exception.Message)" -ForegroundColor Red
    throw
