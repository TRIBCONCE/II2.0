                     @{Label="%"; Expression={"{0:P2}" -f ($_.Value / $RealUsersCount)}; Width=10} -AutoSize

    Write-Host "Всего активных сотрудников в 1С: $($Users1C.Count)" -ForegroundColor Yellow
    Write-Host "Реальных пользователей для анализа: $RealUsersCount" -ForegroundColor Green
    Write-Log "Всего активных сотрудников в 1С: $($Users1C.Count)"
    Write-Log "Реальных пользователей для анализа: $RealUsersCount"

    # Для Zabbix исключаем служебную категорию "(не указано)" — она остаётся только в логах
