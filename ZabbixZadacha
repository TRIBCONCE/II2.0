try {
    Import-Module ImportExcel -ErrorAction Stop

    # --- Справочник (имя колонки с названием = имя листа) ---
    $dict = @{}
    foreach ($sheetName in @("department","dep","dep1")) {
        $sheetDict = @{}
        foreach ($row in (Import-Excel -Path $XLSX_PATH -WorksheetName $sheetName -ErrorAction Stop)) {
            $block = ([string]$row.Block).Trim()
            $name  = ([string]$row.$sheetName).Trim()
            if ($block -and $name) { $sheetDict[$name.ToLower()] = $block }
        }
        $dict[$sheetName] = $sheetDict
    }

    # --- Сотрудники из БД (фильтры декрета и увольнения в SQL) ---
    $sql = @"
SELECT department, dep, dep1, dokko
FROM $SQL_VIEW
WHERE DecrOtpusk = 0
  AND (UvDate IS NULL OR UvDate > @today)
  AND Synonym = N'Основное место работы'
  AND fio IS NOT NULL AND LTRIM(RTRIM(fio)) <> ''
"@
    $conn = New-Object System.Data.SqlClient.SqlConnection(
        "Server=$SQL_SERVER;Database=$SQL_DB;",
        (New-Object System.Data.SqlClient.SqlCredential($SqlUser, $SqlPwd)))
    $conn.Open()
    $cmd = $conn.CreateCommand(); $cmd.CommandText = $sql
    [void]$cmd.Parameters.Add((New-Object System.Data.SqlClient.SqlParameter("@today",[System.Data.SqlDbType]::Date)))
    $cmd.Parameters["@today"].Value = $today
    $dt = New-Object System.Data.DataTable
    (New-Object System.Data.SqlClient.SqlDataAdapter($cmd)).Fill($dt) | Out-Null
    $conn.Close()
    $Users1C = $dt.Rows

    # --- Определение блока: перебор всех уровней по всем листам (как в исходном TXT-скрипте) ---
    function Resolve-Block {
        param($E, $Dict)
        foreach ($f in @("department","dep","dep1")) {
            $v = ([string]$E.$f).Trim()
            if ($v) {
                $k = $v.ToLower()
                foreach ($sheet in @("department","dep","dep1")) {
                    $b = $Dict[$sheet][$k]
                    if ($b) { return $b }
                }
            }
        }
        if (([string]$E.dokko).Trim()) { return $DEFAULT_BLOCK }
        return $NODATA_BLOCK
    }

    Write-Host "`nПодсчёт по блокам" -ForegroundColor Green

