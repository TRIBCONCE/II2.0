# 2.1 Вспомогательный хэш для проверки статуса AD (кто НЕ уволен в 1С)
    # Обновлен под новые условия увольнения и Unit
    $qActive1C = @"
    SELECT DISTINCT Tab_Numb 
    FROM IC.Empl_WT_USPS 
    WHERE (
        UvDate IS NULL 
        OR (UvDate > CAST(GETDATE() AS date) AND Unit = 1)
    )
    AND Unit >= 1
"@
    $dtActive1C = Invoke-Sql $qActive1C
    $active1CHash = @{}
    if ($dtActive1C -and $dtActive1C.Rows) {
        foreach ($row in $dtActive1C.Rows) {
            $t = "$($row.Tab_Numb)".Trim(); if ($t) { $active1CHash[$t] = $true }
        }
    }

    # 2.2 Основной запрос к представлению 1С (с новым условием и JOIN)
    $sql1C = @"
    SELECT e.department, e.dep, e.dep1, e.dokko, e.Tab_Numb, e.fio
    FROM IC.v_Empl_info e
    JOIN IC.Empl_WT_USPS t ON t.Tab_Numb = e.Tab_Numb
    WHERE e.DecrOtpusk = 0
      AND e.fio IS NOT NULL 
      AND LTRIM(RTRIM(e.fio)) <> ''
      -- Объединенный блок проверки дат увольнения и типов занятости
      AND (
          (e.UvDate IS NULL AND e.Synonym = N'Основное место работы')
          OR 
          (e.UvDate > CAST(GETDATE() AS date) AND t.Unit = 1)
      )
      -- Глобальное исключение сотрудников, у которых Unit < 1
      AND t.Unit >= 1
"@
    $dt = Invoke-Sql $sql1C
    $Users1C = $dt.Rows