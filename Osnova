# Фиксируем время начала
$timestart = Get-Date

# Получаем всех активных пользователей с нужными атрибутами
$AllUsersOn = Get-ADUser -Filter { enabled -eq $true } -Properties division, samaccountname, DistinguishedName, name

# Создаём хэш-таблицу для подсчёта уникальных значений division
$DivisionCount = @{}

# Массив для пользователей без division — сохраняем DistinguishedName целиком
$UsersWithoutDivision = [System.Collections.Generic.List[PSObject]]::new()

# Счётчик исключённых
$ExcludedCount = 0

# Проходим по пользователям, фильтруем и считаем
foreach ($User in $AllUsersOn) {
    $sam = $User.samaccountname
    $name = $User.name
    $dn = $User.DistinguishedName
    
    # Исключаем сервисные, административные и вендорские учётки
    if (
        $sam -like "s-*" -or $sam -like "sl-*" -or
        $sam -like "*test*" -or $sam -like "Health*" -or
        $sam -like "room*" -or $sam -like "sp-*" -or
        $sam -like "st-*" -or $sam -like "audit*" -or
        $sam -like "temp*" -or $sam -like "esas*" -or
        $name -like "Сервисная*" -or
        $sam -like "a-*" -or $sam -like "z-*" -or
        $dn -like "*сторон*"
    ) {
        $ExcludedCount++
        continue
    }
    
    # Считаем division
    $div = $User.division
    if ($div) {
        if ($DivisionCount.ContainsKey($div)) {
            $DivisionCount[$div]++
        } else {
            $DivisionCount[$div] = 1
        }
    } else {
        # Сохраняем пользователя без division
        $UsersWithoutDivision.Add([PSCustomObject]@{
            Name             = $name
            SamAccountName   = $sam
            DistinguishedName = $dn
        })
        
        $emptyKey = "(не указано)"
        if ($DivisionCount.ContainsKey($emptyKey)) {
            $DivisionCount[$emptyKey]++
        } else {
            $DivisionCount[$emptyKey] = 1
        }
    }
}

# Считаем итоговое количество "живых" пользователей
$RealUsersCount = ($DivisionCount.Values | Measure-Object -Sum).Sum

# Выводим статистику
Write-Host "`n=== Статистика по подразделениям (division) — реальные пользователи ===" -ForegroundColor Green
Write-Host "Всего уникальных значений: $($DivisionCount.Count)`n"

$DivisionCount.GetEnumerator() | 
    Sort-Object Value -Descending | 
    Format-Table @{Label="Подразделение"; Expression={$_.Key}; Width=50}, 
                 @{Label="Кол-во пользователей"; Expression={$_.Value}; Width=20}, 
                 @{Label="%"; Expression={"{0:P2}" -f ($_.Value / $RealUsersCount)}; Width=10} -AutoSize

# Итоговые количества
Write-Host "Всего активных пользователей в AD: $($AllUsersOn.Count)" -ForegroundColor Yellow
Write-Host "Исключено (служебные/админские/вендоры): $ExcludedCount" -ForegroundColor Magenta
Write-Host "Реальных пользователей для анализа: $RealUsersCount" -ForegroundColor Green

# Выводим пользователей без division
if ($UsersWithoutDivision.Count -gt 0) {
    Write-Host "`n=== Пользователи без указанного division ($($UsersWithoutDivision.Count) шт.) ===" -ForegroundColor Red
    $UsersWithoutDivision | 
        Sort-Object Name | 
        Format-Table Name, SamAccountName, 
                      @{Label="DistinguishedName"; Expression={$_.DistinguishedName}; Width=120} -AutoSize
}

# Время выполнения
$timestop = Get-Date
$TimeSum = $timestop - $timestart
Write-Host "`nВремя выполнения: $($TimeSum.Hours)ч $($TimeSum.Minutes)м $($TimeSum.Seconds)с" -ForegroundColor Cyan