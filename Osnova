cls

$timestart = Get-Date
$today = Get-Date -Format dd.MM.yyyy
$time = Get-Date -Format "dd.MM.yyyy HH:mm"

# --- Настройки путей и логирования ---
$LogPath = "C:\Scripts\Zabbix_division_objects\AllUsersBlocksDiscoveryLOG.log"
$OUTPUT_PATH = "\\p-rpait-syn01\c$\Program Files\Zabbix Agent\scripts\AD\ADData_UsersBlocks_Discovery.txt"
$ScriptStatus = "SUCCESS"

# Функция записи в лог
function Write-Log {
    param(
        [string]$Message
    )
    $TimeStamp = Get-Date -Format "dd.MM.yyyy HH:mm:ss"
    Add-Content -Path $LogPath -Value "[$TimeStamp] $Message" -Encoding UTF8
}

# Функция для работы с SQL
function Invoke-Sql([string]$q){
    $cs="Server=$SqlServer;Database=$SqlDb;User Id=$SqlUser;Password=$SqlPass;"
    $cn=New-Object System.Data.SqlClient.SqlConnection $cs; $cn.Open()
    $cmd=$cn.CreateCommand(); $cmd.CommandText=$q
    $da=New-Object System.Data.SqlClient.SqlDataAdapter $cmd
    $dt=New-Object System.Data.DataTable; [void]$da.Fill($dt); $cn.Close(); ,$dt
}

try {
    Import-Module ActiveDirectory -ErrorAction Stop

    Write-Host "`n[1/3] Запрос к БД 1С для получения работающих сотрудников..." -ForegroundColor Cyan
    Write-Log "Запуск скрипта проверки отключенных в AD, но активных в 1С пользователей..."

    # Шаг 1: Собираем из 1С все табельные номера сотрудников, у которых ОТСУТСТВУЕТ дата увольнения (UvDate IS NULL)
    $qActive1C = "SELECT DISTINCT Tab_Numb FROM IC.Empl_WT_USPS WHERE UvDate IS NULL"
    $dtActive1C = Invoke-Sql $qActive1C

    $active1CHash = @{}
    if ($dtActive1C -and $dtActive1C.Rows) {
        foreach ($row in $dtActive1C.Rows) {
            $t = "$($row.Tab_Numb)".Trim()
            if ($t) { $active1CHash[$t] = $true }
        }
    }
    Write-Log "Загружено активных табельных номеров из 1С: $($active1CHash.Count)"

    # Шаг 2: Подключение к AD и получение отключенных пользователей
    Write-Host "[2/3] Получение отключенных пользователей из Active Directory..." -ForegroundColor Cyan

    $key_path = "\\p-rpait-syn01\c$\Scripts\cyph_keys\aes.key"
    $ab_pwd_path = "\\p-rpait-syn01\c$\Scripts\cyph_keys\pwd_abw.txt"

    $ab_password = Get-Content $ab_pwd_path | ConvertTo-SecureString -Key (Get-Content $key_path)
    $ab_creds = New-Object System.Management.Automation.PSCredential("ABB-WIN\s-ad-expertise", $ab_password)

    # Запрашиваем свойство wWWHomePage для извлечения табельного номера
    $AllUsersOn = Get-ADUser `
        -Filter "Enabled -ne 'True' -and (division -like '*')" `
        -Credential $ab_creds `
        -Properties division, samaccountname, DistinguishedName, name, whenCreated, employeeType, initials, wWWHomePage

    $LimitDate = (Get-Date).AddDays(-3)

    # Исключения по initials
    $ExcludeInitials = @("abdt","vnsov","1/40")

    # Ручные исключения по логинам SamAccountName
    $ExcludeSamAccounts = @(
        "TantushjanAM"
    )

    $ExcludeSamAccountsHash = @{}
    foreach ($x in $ExcludeSamAccounts) {
        $x = ([string]$x).Trim()
        if ($x) { $ExcludeSamAccountsHash[$x] = $true }
    }

    $DivisionCount = @{}
    $ExcludedCount = 0

    # Список для сбора пользователей целевого блока
    $ApparatUsers = New-Object System.Collections.ArrayList

    foreach ($User in $AllUsersOn) {

        $sam = ([string]$User.samaccountname).Trim()
        $name = $User.name
        $dn = $User.DistinguishedName
        $tab = "$($User.wWWHomePage)".Trim() # Получаем табельный номер из карточки AD

        if (
                $User.whenCreated -gt $LimitDate -or
                (@("service","vendor") -contains ([string]$User.employeeType).Trim().ToLower()) -or
                $ExcludeInitials -contains ([string]$User.initials).Trim() -or
                $ExcludeSamAccountsHash.ContainsKey($sam) -or

                $sam -like "Health*" -or
                $sam -like "audit*" -or
                $sam -like "esas*" -or
                $sam -like "a-*" -or
                $sam -like "z-*" -or
                $name -like "*`$*" -or
                $name -like "*Администратор*" -or
                $name -like "*Тестовая*" -or
                $dn -like "*сторон*" -or

                # ГЛАВНОЕ УСЛОВИЕ: Если табельного номера НЕТ среди активных в 1С (значит он уволен или его нет в базе), мы его ИСКЛЮЧАЕМ
                (-not $active1CHash.ContainsKey($tab))
        ) {
                $ExcludedCount++
                continue
        }

        $div = $User.division

        if ($div) {
            if ($DivisionCount.ContainsKey($div)) { $DivisionCount[$div]++ }
            else { $DivisionCount[$div] = 1 }
        }
        else {
            $emptyKey = "(не указано)"
            if ($DivisionCount.ContainsKey($emptyKey)) { $DivisionCount[$emptyKey]++ }
            else { $DivisionCount[$emptyKey] = 1 }
        }

        # Если пользователь прошел все фильтры и относится к ИТ-блоку — сохраняем параметры
        if (([string]$div).Trim() -eq "Информационно-технологический блок") {
            [void]$ApparatUsers.Add([PSCustomObject]@{
                Name              = $User.name
                SamAccountName    = $sam
                TabNumber         = $tab
                Division          = $div
                EmployeeType      = $User.employeeType
                Initials          = $User.initials
                WhenCreated       = if ($User.whenCreated) { $User.whenCreated.ToString("dd.MM.yyyy HH:mm") } else { "" }
                DistinguishedName = $dn
            })
        }
    }

    $discovery = foreach ($k in $DivisionCount.Keys) {
        @{ '{#DIVISION}' = $k }
    }

    $RealUsersCount = ($DivisionCount.Values | Measure-Object -Sum).Sum
    if ($null -eq $RealUsersCount) { $RealUsersCount = 0 }

    # Формирование JSON-файла для Zabbix Discovery
    Write-Host "[3/3] Запись файла Zabbix Discovery..." -ForegroundColor Cyan
    $payload = [ordered]@{
        discovery = @($discovery)
        counts = $DivisionCount
        metadata = @{
            TotalActiveUsers  = $AllUsersOn.Count
            ExcludedUsers     = $ExcludedCount
            RealUsers         = $RealUsersCount
            UniqueDivisions   = $DivisionCount.Count
            GeneratedAt       = $time
            ScriptDurationSec = [math]::Round(((Get-Date) - $timestart).TotalSeconds, 2)
        }
    }

    $json = $payload | ConvertTo-Json -Depth 4
    $outputDir = Split-Path $OUTPUT_PATH -Parent
    if (-not (Test-Path $outputDir)) { New-Item -ItemType Directory -Path $outputDir -Force | Out-Null }
    [System.IO.File]::WriteAllText($OUTPUT_PATH, $json, [System.Text.UTF8Encoding]::new($false))
    Write-Log "Файл успешно сохранен в $OUTPUT_PATH"

    # --- ВЫВОД В КОНСОЛЬ ДЕТАЛИЗАЦИИ ПО ИТ-БЛОКУ ---
    if ($ApparatUsers.Count -gt 0) {
        Write-Host "`n=========== ПОЛЬЗОВАТЕЛИ БЛОКА 'ИНФОРМАЦИОННО-ТЕХНОЛОГИЧЕСКИЙ БЛОК' ===========" -ForegroundColor Cyan
        $ApparatUsers | Format-Table -AutoSize
        Write-Host "Итого в блоке (после фильтрации и проверки по 1С): $($ApparatUsers.Count)" -ForegroundColor Yellow
        Write-Host "================================================================================`n" -ForegroundColor Cyan
    } else {
        Write-Host "`n[!] В блоке 'Информационно-технологический блок' не найдено подходящих пользователей (активных в 1С).`n" -ForegroundColor Red
    }

    # --- ВЫВОД СТАТИСТИКИ ПО ВСЕМ БЛОКАМ ---
    Write-Host "Подсчёт по блокам" -ForegroundColor Green
    Write-Host "Всего уникальных значений: $($DivisionCount.Count)`n"

    $DivisionCount.GetEnumerator() |
        Sort-Object Value -Descending |
        Format-Table @{Label="Подразделение"; Expression={$_.Key}; Width=50},
                     @{Label="Кол-во"; Expression={$_.Value}; Width=10},
                     @{Label="%"; Expression={
                         if ($RealUsersCount -gt 0) { "{0:P2}" -f ($_.Value / $RealUsersCount) } else { "0,00%" }
                     }; Width=10} -AutoSize

    # --- ТРЕБУЕМЫЙ ВЫВОД ЦЕЛЬНЫХ И СУММАРНЫХ СЧЕТЧИКОВ ---
    Write-Host "=================== ИТОГОВЫЕ СЧЕТЧИКИ ===================" -ForegroundColor Green
    Write-Host "Всего отключенных пользователей в AD:                                    $($AllUsersOn.Count)" -ForegroundColor Yellow
    Write-Host "Исключено (служебные/тестовые/реально уволенные по данным 1С):           $ExcludedCount" -ForegroundColor Magenta
    Write-Host "Реальных пользователей для анализа (ОТКЛЮЧЕНЫ В AD, НО РАБОТАЮТ В 1С):    $RealUsersCount" -ForegroundColor Green
    Write-Host "=========================================================" -ForegroundColor Green

    $timestop = Get-Date
    $TimeSum = $timestop - $timestart
    Write-Host "`nВремя выполнения: $($TimeSum.Hours)ч $($TimeSum.Minutes)м $($TimeSum.Seconds)с" -ForegroundColor Cyan
    Write-Log "Скрипт успешно завершен. Результат анализа: $RealUsersCount пользователей."

}
catch {
    $ScriptStatus = "ERROR"
    Write-Host "`nОШИБКА: $($_.Exception.Message)" -ForegroundColor Red
    Write-Log "КРИТИЧЕСКАЯ ОШИБКА ВЫПОЛНЕНИЯ: $($_.Exception.Message)"
    throw
}