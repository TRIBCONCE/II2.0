try {
    Import-Module ActiveDirectory -ErrorAction Stop

    $key_path = "\\p-rpait-syn01\c$\Scripts\cyph_keys\aes.key"
    $ab_pwd_path = "\\p-rpait-syn01\c$\Scripts\cyph_keys\pwd_abw.txt"

    $ab_password = Get-Content $ab_pwd_path | ConvertTo-SecureString -Key (Get-Content $key_path)
    $ab_creds = New-Object System.Management.Automation.PSCredential("ABB-WIN\s-ad-expertise", $ab_password)

    $AllUsersOn = Get-ADUser `
        -Filter { enabled -eq $true } `
        -Credential $ab_creds `
        -Properties division, samaccountname, DistinguishedName, name, whenCreated, employeeType, initials

    $LimitDate = (Get-Date).AddDays(-3)

    # Исключения по initials
    $ExcludeInitials = @("abdt","vnsov","1/40")

    # Ручные исключения по логинам SamAccountName
    # Эти УЗ вообще не будут попадать в счетчики
    $ExcludeSamAccounts = @(
        "TantushjanAM"
    )

    $ExcludeSamAccountsHash = @{}
    foreach ($x in $ExcludeSamAccounts) {
        $x = ([string]$x).Trim()
        if ($x) {
            $ExcludeSamAccountsHash[$x] = $true
        }
    }

    $DivisionCount = @{}

    # Счётчик исключённых
    $ExcludedCount = 0

    # + ДОБАВЛЕНО: Создаем список для сбора пользователей "Аппарат правления"
    $ApparatUsers = New-Object System.Collections.ArrayList

    foreach ($User in $AllUsersOn) {

        $sam = ([string]$User.samaccountname).Trim()
        $name = $User.name
        $dn = $User.DistinguishedName

        if (
                $User.whenCreated -gt $LimitDate -or
                (@("service","vendor") -contains ([string]$User.employeeType).Trim().ToLower()) -or
                $ExcludeInitials -contains ([string]$User.initials).Trim() -or
                $ExcludeSamAccountsHash.ContainsKey($sam) -or

                $sam -like "Health*" -or
                $sam -like "audit*" -or
                $sam -like "esas*" -or
                $sam -like "a-*" -or
                $sam -like "z-*" -or
                $name -like "*`$*" -or
                $name -like "*Администратор*" -or
                $name -like "*Тестовая*" -or
                $dn -like "*Отключенные пользователи*" -or
                $dn -like "*сторон*"
        ) {
                $ExcludedCount++
                continue
        }

        $div = $User.division

        if ($div) {
            if ($DivisionCount.ContainsKey($div)) {
                $DivisionCount[$div]++
            }
            else {
                $DivisionCount[$div] = 1
            }
        }
        else {
            $emptyKey = "(не указано)"

            if ($DivisionCount.ContainsKey($emptyKey)) {
                $DivisionCount[$emptyKey]++
            }
            else {
                $DivisionCount[$emptyKey] = 1
            }
        }

        # + ДОБАВЛЕНО: Если пользователь прошел все фильтры и его блок "Аппарат правления" - сохраняем его параметры
        if (([string]$div).Trim() -eq "Аппарат правления") {
            [void]$ApparatUsers.Add([PSCustomObject]@{
                Name              = $User.name
                SamAccountName    = $sam
                Division          = $div
                EmployeeType      = $User.employeeType
                Initials          = $User.initials
                WhenCreated       = if ($User.whenCreated) { $User.whenCreated.ToString("dd.MM.yyyy HH:mm") } else { "" }
                DistinguishedName = $dn
            })
        }
    }

    $discovery = foreach ($k in $DivisionCount.Keys) {
        @{ '{#DIVISION}' = $k }
    }

    $RealUsersCount = ($DivisionCount.Values | Measure-Object -Sum).Sum

    if ($null -eq $RealUsersCount) {
        $RealUsersCount = 0
    }

    $payload = [ordered]@{
        discovery = @($discovery)
        counts = $DivisionCount
        metadata = @{
            TotalActiveUsers  = $AllUsersOn.Count
            ExcludedUsers     = $ExcludedCount
            RealUsers         = $RealUsersCount
            UniqueDivisions   = $DivisionCount.Count
            GeneratedAt       = $time
            ScriptDurationSec = [math]::Round(((Get-Date) - $timestart).TotalSeconds, 2)
        }
    }

    $json = $payload | ConvertTo-Json -Depth 4

    #$outputPath = "\\p-rpait-syn01\c$\Program Files\Zabbix Agent\scripts\AD\ADData_UsersBlocks_Discovery.txt"


    # + ДОБАВЛЕНО: Вывод списка пользователей "Аппарат правления" в консоль
    if ($ApparatUsers.Count -gt 0) {
        Write-Host "`n=========== ПОЛЬЗОВАТЕЛИ БЛОКА 'АППАРАТ ПРАВЛЕНИЯ' ===========" -ForegroundColor Cyan
        $ApparatUsers | Format-Table -AutoSize
        Write-Host "Итого в Аппарате правления (после фильтрации): $($ApparatUsers.Count)" -ForegroundColor Yellow
        Write-Host "================================================================`n" -ForegroundColor Cyan
    } else {
        Write-Host "`n[!] В блоке 'Аппарат правления' не найдено ни одного пользователя подходящего под условия.`n" -ForegroundColor Red
    }


    Write-Host "Подсчёт по блокам" -ForegroundColor Green
    Write-Host "Всего уникальных значений: $($DivisionCount.Count)`n"

    $DivisionCount.GetEnumerator() |
        Sort-Object Value -Descending |
        ForEach-Object {
            if ($RealUsersCount -gt 0) {
                $percent = "{0:P2}" -f ($_.Value / $RealUsersCount)
            }
            else {
                $percent = "0,00%"
            }
        }

    $DivisionCount.GetEnumerator() |
        Sort-Object Value -Descending |
        Format-Table @{Label="Подразделение"; Expression={$_.Key}; Width=50},
                     @{Label="Кол-во"; Expression={$_.Value}; Width=10},
                     @{Label="%"; Expression={
                         if ($RealUsersCount -gt 0) {
                             "{0:P2}" -f ($_.Value / $RealUsersCount)
                         }
                         else {
                             "0,00%"
                         }
                     }; Width=10} -AutoSize

    Write-Host "Всего активных пользователей в AD: $($AllUsersOn.Count)" -ForegroundColor Yellow
    Write-Host "Исключено (служебные/админские/вендоры/ручные исключения): $ExcludedCount" -ForegroundColor Magenta
    Write-Host "Реальных пользователей для анализа: $RealUsersCount" -ForegroundColor Green


    $timestop = Get-Date
    $TimeSum = $timestop - $timestart

    Write-Host "`nВремя выполнения: $($TimeSum.Hours)ч $($TimeSum.Minutes)м $($TimeSum.Seconds)с" -ForegroundColor Cyan
    Write-Host "Файл сохранён." -ForegroundColor Green

}
catch {
    $ScriptStatus = "ERROR"
    Write-Host "`nОШИБКА: $($_.Exception.Message)" -ForegroundColor Red
    throw
}