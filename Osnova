cls

$timestart = Get-Date
$today = (Get-Date).Date
$time = Get-Date -Format "dd.MM.yyyy HH:mm"

# --- Настройки путей ---
$LogPath = "C:\Users\z-BorodinES\Desktop\ZabbixZadacha\HR_Movement_DiscoveryLOG.log"
$OUTPUT_PATH = "\\p-rpait-syn01\c$\Program Files\Zabbix Agent\scripts\AD\ADData_HRMovement_Discovery_1C.txt"

# Статус выполнения
$ScriptStatus = "SUCCESS"

# Функция записи в лог
function Write-Log {
    param([string]$Message)
    $TimeStamp = Get-Date -Format "dd.MM.yyyy HH:mm:ss"
    Add-Content -Path $LogPath -Value "[$TimeStamp] $Message" -Encoding UTF8
}

function Invoke-Sql([string]$q){
    $cs="Server=$SqlServer;Database=$SqlDb;User Id=$SqlUser;Password=$SqlPass;"
    $cn=New-Object System.Data.SqlClient.SqlConnection $cs; $cn.Open()
    $cmd=$cn.CreateCommand(); $cmd.CommandText=$q
    $da=New-Object System.Data.SqlClient.SqlDataAdapter $cmd
    $dt=New-Object System.Data.DataTable; [void]$da.Fill($dt); $cn.Close(); ,$dt
}

try {
    Write-Host "`n[1/3] Выполнение SQL-запросов..." -ForegroundColor Cyan
    Write-Log "Запуск совмещенного сбора данных (Трудоустроенные и Уволенные за сегодня)..."

    # SQL Скрипт 1: Список трудоустроенных за сегодня
    $qHired = @"
    SELECT e.LastName, e.FirstName, e.MiddleName, e.Tab_Numb, e.IDPerson, e.PrDate
    FROM IC.Empl_WT_USPS e
    WHERE CAST(e.PrDate AS date) = CAST(GETDATE() AS date)
      AND e.EmplType = 'AD273B83-8100-11E8-A94B-005056902B6A'
    ORDER BY e.LastName
"@

    # SQL Скрипт 2: Список уволенных за сегодня
    $qTerminated = @"
    SELECT e.LastName, e.FirstName, e.MiddleName, e.Tab_Numb, e.IDPerson, e.UvDate
    FROM IC.Empl_WT_USPS e
    WHERE CAST(e.UvDate AS date) = CAST(GETDATE() AS date)
    ORDER BY e.LastName
"@

    # SQL Скрипт 3: База сотрудников для расчета %
    $qTotal = "SELECT COUNT(EmplID) AS TotalCount FROM IC.Empl_WT_USPS WHERE UvDate IS NULL AND StatusEmpl != 'Отпуск по уходу за ребенком'"

    # Выполняем все три запроса
    $HiredResult      = Invoke-Sql $qHired
    $TerminatedResult = Invoke-Sql $qTerminated
    $TotalResult      = Invoke-Sql $qTotal

    # Подсчет метрик
    $HiredCount      = if ($HiredResult.Rows) { $HiredResult.Rows.Count } else { 0 }
    $TerminatedCount = if ($TerminatedResult.Rows) { $TerminatedResult.Rows.Count } else { 0 }
    $TotalUsers      = if ($TotalResult.Rows) { $TotalResult.Rows[0].TotalCount } else { 1 } # Защита от деления на 0

    # Расчет процентов
    $HiredPercent      = [math]::Round((($HiredCount / $TotalUsers) * 100), 2)
    $TerminatedPercent = [math]::Round((($TerminatedCount / $TotalUsers) * 100), 2)

    Write-Log "Метрики: Принято=$HiredCount ($HiredPercent%), Уволено=$TerminatedCount ($TerminatedPercent%), Всего активных=$TotalUsers"

    # --- ФОРМИРОВАНИЕ ЕДИНОГО ZABBIX DISCOVERY ---
    Write-Host "[2/3] Формирование Zabbix Discovery JSON..." -ForegroundColor Cyan

    $discovery = @(
        @{ '{#EMPLOYEETYPE}' = 'Трудоустроенные_сегодня' },
        @{ '{#EMPLOYEETYPE}' = 'Уволенные_сегодня' },
        @{ '{#EMPLOYEETYPE}' = 'Процент_трудоустроенных' },
        @{ '{#EMPLOYEETYPE}' = 'Процент_уволенных' },
        @{ '{#EMPLOYEETYPE}' = 'Пользователей_всего' }
    )

    $payload = [ordered]@{
        discovery = $discovery
        counts = @{
            Трудоустроенные_сегодня = $HiredCount
            Уволенные_сегодня       = $TerminatedCount
            Процент_трудоустроенных = $HiredPercent
            Процент_уволенных       = $TerminatedPercent
            Пользователей_всего     = $TotalUsers
        }
        metadata = @{
            TotalActiveUsers  = $TotalUsers
            GeneratedAt       = $time
            ScriptDurationSec = [math]::Round(((Get-Date) - $timestart).TotalSeconds, 2)
        }
    }

    $json = $payload | ConvertTo-Json -Depth 4

    # Сохранение итогового JSON файла
    $outputDir = Split-Path $OUTPUT_PATH -Parent
    if (-not (Test-Path $outputDir)) {
        New-Item -ItemType Directory -Path $outputDir -Force | Out-Null
    }
    [System.IO.File]::WriteAllText($OUTPUT_PATH, $json, [System.Text.UTF8Encoding]::new($false))
    Write-Log "Файл Zabbix Discovery успешно сохранен: $OUTPUT_PATH"

    # --- ВЫВОД В КОНСОЛЬ ---
    Write-Host "`n=========== СВОДНЫЕ ИТОГИ ДВИЖЕНИЯ КАДРОВ ===========" -ForegroundColor Green
    Write-Host "Всего активных сотрудников в банке: $TotalUsers" -ForegroundColor Yellow
    Write-Host "Трудоустроено за сегодня (приём):   $HiredCount чел. ($HiredPercent %)" -ForegroundColor Green
    Write-Host "Уволено за сегодня:                  $TerminatedCount чел. ($TerminatedPercent %)" -ForegroundColor Red
    Write-Host "=====================================================" -ForegroundColor Green

    $timestop = Get-Date
    $TimeSum = $timestop - $timestart

    Write-Host "`nВремя выполнения: $($TimeSum.Hours)ч $($TimeSum.Minutes)м $($TimeSum.Seconds)с" -ForegroundColor Cyan
    Write-Host "Файл сохранён." -ForegroundColor Green
    Write-Log "Время выполнения: $($TimeSum.Hours)ч $($TimeSum.Minutes)м $($TimeSum.Seconds)с"
    Write-Log "СТАТУС: $ScriptStatus"

} catch {
    $ScriptStatus = "ERROR"
    Write-Log ""
    Write-Log "СТАТУС: ERROR"
    Write-Log "Ошибка: $($_.Exception.Message)"
    Write-Log "Полная информация: $_"

    Write-Host "`nОШИБКА: $($_.Exception.Message)" -ForegroundColor Red
    throw
}